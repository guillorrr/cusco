# =============================================================================
# CUSCO - Node + Angular Scaffold
# =============================================================================

# App
APP_NAME=cusco
# Docker Compose project name. Derived from APP_NAME so that container, network
# and volume names never depend on what the repo directory happens to be called
# (Compose would otherwise fall back to the directory basename).
COMPOSE_PROJECT_NAME=${APP_NAME}
DOMAIN=cusco.local
PROTOCOL=https
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_NAME=cusco
DB_USER=cusco
DB_PASSWORD=cusco_secret
DB_ROOT_PASSWORD=root_secret
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# API (NestJS)
API_PORT=3000
API_PREFIX=api
API_VERSION=v1
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600

# Admin seed (consumed by `npm run prisma:seed:admin` only).
# Leave ADMIN_PASSWORD empty to generate a random password printed once at seed time.
# Setting a value here is convenient for local dev; for production, prefer leaving
# it empty and capturing the generated password from the first run's logs.
ADMIN_EMAIL=admin@cusco.local
ADMIN_PASSWORD=

# Frontend (Angular)
FRONTEND_PORT=4200

# Nginx edge
# Max request body size at the reverse proxy (uploads, multipart forms, etc.).
CLIENT_MAX_BODY_SIZE=32M

# Docker Ports
FORWARD_HTTP_PORT=80
FORWARD_HTTPS_PORT=443
FORWARD_DB_PORT=5432
FORWARD_API_PORT=3000
FORWARD_FRONTEND_PORT=4200
FORWARD_PGADMIN_PORT=8082
FORWARD_MAILHOG_PORT=8025
FORWARD_STORYBOOK_PORT=6006
FORWARD_MAILHOG_SMTP_PORT=1025

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# pgAdmin
# Ojo con el dominio: pgAdmin valida este email al arrancar y rechaza los TLD
# reservados (.local, .localhost, .test, .invalid...) con "The part after the
# @-sign is a special-use or reserved name". Si le ponés uno, el contenedor
# queda en loop de reinicio. Usá un TLD real.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Mail (Mailhog)
MAIL_HOST=mailhog
MAIL_PORT=1025
