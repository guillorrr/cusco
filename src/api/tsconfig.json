{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    // npm workspaces hoists every @types package to the monorepo root, and TS
    // auto-includes all of them. Without this, @types/jasmine (pulled in by the
    // frontend) shadows the jest globals and the specs fail to compile.
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@core/*": ["src/core/*"],
      "@modules/*": ["src/modules/*"],
      "@features/*": ["src/features/*"],
      "@common/*": ["src/common/*"]
    }
  }
}
