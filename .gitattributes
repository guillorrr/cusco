# Default: normalize text files to LF in repo, check out as LF on all platforms
* text=auto eol=lf

# Binary assets (skip text normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Windows-only scripts must keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
